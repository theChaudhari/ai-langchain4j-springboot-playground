{
  "info": {
    "name": "AI-Powered Request Validator",
    "description": "Postman Collection for AI-Powered Request Validator using Spring Boot + LangChain4j + Google Gemini",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "👤 User Registration",
      "item": [
        {
          "name": "✅ Register Valid User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"email\": \"john.smith@gmail.com\",\n  \"password\": \"SecurePass@123\",\n  \"phone\": \"+1-555-234-5678\",\n  \"address\": \"123 Main St, New York, NY\",\n  \"age\": 28,\n  \"bio\": \"Software developer with 5 years of experience\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Registers a valid user with realistic data. Expected response: 200 OK with success message and high confidence score."
          },
          "response": [
            {
              "name": "200 OK - User Registered",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"message\": \"User registered successfully!\",\n  \"confidenceScore\": 95,\n  \"warnings\": []\n}"
            }
          ]
        },
